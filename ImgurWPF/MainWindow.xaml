<Window
    x:Class="ImgurWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:galleryItem="clr-namespace:ImgurWPF.Components.GalleryItem"
    xmlns:local="clr-namespace:ImgurWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pagination="clr-namespace:ImgurWPF.Components.Pagination"
    xmlns:paginationViewModel="clr-namespace:ImgurWPF.Components.Pagination"
    xmlns:search="clr-namespace:ImgurWPF.Components.Search"
    xmlns:searchViewModel="clr-namespace:ImgurWPF.Components.Search"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <Window.Resources>
        <DataTemplate DataType="{x:Type searchViewModel:SearchViewModel}">
            <search:SearchComponent Command="{Binding DataContext.SearchCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type paginationViewModel:PaginationViewModel}">
            <pagination:PaginationComponent Command="{Binding DataContext.SelectedPageCommand, RelativeSource={RelativeSource AncestorType=Window}}" TotalItemsCount="{Binding DataContext.TotalItemsCount, RelativeSource={RelativeSource AncestorType=Window}}" />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  搜尋  -->
        <StackPanel Grid.Row="0">
            <ContentControl Content="{Binding SearchViewModel}" />
        </StackPanel>
        <!--<search:SearchComponent  Command="{Binding DataContext.SearchCommand, RelativeSource={RelativeSource AncestorType=Window}}" />-->

        <!--  顯示 image item  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="container" ItemsSource="{Binding CurrentPageItems}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="8" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="250" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--  image item  -->
                        <galleryItem:GalleryItemComponent Width="250" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  pagination  -->
        <!--<pagination:PaginationComponent
            Grid.Row="2"
            Command="{Binding DataContext.SelectedPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            TotalItemsCount="{Binding DataContext.TotalItemsCount, RelativeSource={RelativeSource AncestorType=Window}}" />-->

        <StackPanel Grid.Row="2">
            <ContentControl Content="{Binding PaginationViewModel}" />
        </StackPanel>
    </Grid>
</Window>