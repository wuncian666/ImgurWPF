<UserControl
    x:Class="ImgurWPF.Components.GalleryItem.GalleryItemComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vote="clr-namespace:ImgurWPF.Components.Vote"
    d:DesignHeight="350"
    d:DesignWidth="320"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  現代化配色  -->
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PrimaryText" Color="#212121" />
        <SolidColorBrush x:Key="SecondaryText" Color="#757575" />
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0" />

        <!--  卡片樣式  -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="15"
                        Direction="270"
                        Opacity="0.1"
                        ShadowDepth="2" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                BlurRadius="20"
                                Direction="270"
                                Opacity="0.15"
                                ShadowDepth="4" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  圖片容器樣式  -->
        <Style x:Key="ImageContainer" TargetType="Border">
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="CornerRadius" Value="12,12,0,0" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <!--  標題樣式  -->
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxHeight" Value="44" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!--  統計數字樣式  -->
        <Style x:Key="StatText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
        </Style>

        <!--  Icon 樣式  -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Cursor="Hand" Style="{StaticResource ModernCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  圖片區域  -->
            <Border Grid.Row="0" Style="{StaticResource ImageContainer}">
                <Grid>
                    <Image
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="{Binding cover}"
                        Stretch="UniformToFill">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding DetailCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Image>

                    <!--  漸層遮罩  -->
                    <Border Height="60" VerticalAlignment="Bottom">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="Transparent" />
                                <GradientStop Offset="1" Color="#40000000" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>

            <!--  標題區域  -->
            <Border Grid.Row="1" Padding="16,12">
                <TextBlock Style="{StaticResource TitleText}" Text="{Binding title}" />
            </Border>

            <!--  統計資訊區域  -->
            <Border
                Grid.Row="2"
                Margin="12,0"
                Padding="16,8,16,16"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  投票元件  -->
                    <vote:VoteComponent
                        Grid.Row="2"
                        Grid.Column="0"
                        Command="{Binding DataContext.VoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Score="{Binding DataContext.Score, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Vote="{Binding DataContext.Vote, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" />

                    <!--  間隔  -->
                    <Border Grid.Column="1" />

                    <!--  評論數  -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            Style="{StaticResource IconStyle}"
                            Text="&#xE8F2;" />
                        <TextBlock Style="{StaticResource StatText}" Text="{Binding comment_count, FallbackValue=0}" />
                    </StackPanel>

                    <!--  瀏覽數  -->
                    <StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            Style="{StaticResource IconStyle}"
                            Text="&#xE890;" />
                        <TextBlock Style="{StaticResource StatText}" Text="{Binding views, FallbackValue=0}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>