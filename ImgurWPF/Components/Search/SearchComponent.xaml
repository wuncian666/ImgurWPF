<UserControl
    x:Class="ImgurWPF.Components.Search.SearchComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ImgurWPF.Components.Search"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SearchLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="#444" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SearchInputStyle" TargetType="Control">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style
            x:Key="SearchTextBoxStyle"
            BasedOn="{StaticResource SearchInputStyle}"
            TargetType="TextBox">
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style
            x:Key="SearchComboBoxStyle"
            BasedOn="{StaticResource SearchInputStyle}"
            TargetType="ComboBox">
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style
            x:Key="SearchButtonStyle"
            BasedOn="{StaticResource SearchInputStyle}"
            TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="#2B6CB0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#2B6CB0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="14"
        Background="#FFFFFF"
        BorderBrush="#E6E6E6"
        BorderThickness="1"
        CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Style="{StaticResource SearchLabelStyle}"
                    Text="查詢" />

                <Grid Grid.Column="1">
                    <TextBox
                        x:Name="QueryTextBox"
                        Style="{StaticResource SearchTextBoxStyle}"
                        Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#9AA0A6"
                        IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=QueryTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        請輸入關鍵字…
                    </TextBlock>
                </Grid>
            </Grid>

            <StackPanel
                Grid.Column="1"
                Margin="16,0,16,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,6,0"
                    Style="{StaticResource SearchLabelStyle}"
                    Text="排序" />
                <ComboBox
                    Margin="0,0,14,0"
                    ItemsSource="{Binding SortParams}"
                    SelectedValue="{Binding Sort}"
                    Style="{StaticResource SearchComboBoxStyle}" />

                <TextBlock
                    Margin="0,0,6,0"
                    Style="{StaticResource SearchLabelStyle}"
                    Text="時間區間" />
                <ComboBox
                    ItemsSource="{Binding WindowParams}"
                    SelectedValue="{Binding Window}"
                    Style="{StaticResource SearchComboBoxStyle}" />
            </StackPanel>

            <Button
                Grid.Column="2"
                Command="{Binding SearchCommand}"
                Content="查詢"
                Style="{StaticResource SearchButtonStyle}" />
        </Grid>
    </Border>
</UserControl>