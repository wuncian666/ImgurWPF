<UserControl
    x:Class="ImgurWPF.Components.Pagination.PaginationComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ImgurWPF.Components.Pagination"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Pagination.ButtonText" Color="#FF111827" />
        <SolidColorBrush x:Key="Pagination.ButtonTextMuted" Color="#FF6B7280" />
        <SolidColorBrush x:Key="Pagination.Border" Color="#FFE5E7EB" />
        <SolidColorBrush x:Key="Pagination.Bg" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="Pagination.BgHover" Color="#FFF3F4F6" />
        <SolidColorBrush x:Key="Pagination.BgPressed" Color="#FFE5E7EB" />
        <SolidColorBrush x:Key="Pagination.ActiveBg" Color="#FF2563EB" />

        <Style x:Key="Pagination.NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Pagination.Bg}" />
            <Setter Property="Foreground" Value="{StaticResource Pagination.ButtonText}" />
            <Setter Property="BorderBrush" Value="{StaticResource Pagination.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Pagination.BgHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Pagination.BgPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Pagination.ButtonTextMuted}" />
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="Pagination.PageButtonStyle"
            BasedOn="{StaticResource Pagination.NavButtonStyle}"
            TargetType="Button">
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Padding" Value="12,6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Pagination.ActiveBg}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{StaticResource Pagination.ActiveBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
        <Button
            x:Name="PreviousButton"
            Margin="6,0,0,0"
            Command="{Binding PreviousPageCommand}"
            Content="&lt;"
            Style="{StaticResource Pagination.NavButtonStyle}" />

        <ItemsControl ItemsSource="{Binding Pages}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding Index}"
                        Content="{Binding Index}"
                        Style="{StaticResource Pagination.PageButtonStyle}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button
            x:Name="NextButton"
            Margin="0,0,6,0"
            Command="{Binding NextPageCommand}"
            Content="&gt;"
            Style="{StaticResource Pagination.NavButtonStyle}" />
    </StackPanel>
</UserControl>